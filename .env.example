# ─────────────────────────────────────────────────────────────────────────────
# Rare Ease — Environment Variables
# Copy this file to .env.local for local development.
# Add all variables to your Vercel project settings for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # NEVER expose this publicly

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://rareease.com                 # No trailing slash

# ── Cashfree Payments ─────────────────────────────────────────────────────────
# Get these from: https://merchant.cashfree.com → Developers → API Keys
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
CASHFREE_ENV=sandbox                                     # sandbox | production
NEXT_PUBLIC_CASHFREE_ENV=sandbox                         # must match CASHFREE_ENV

# ── Shiprocket ────────────────────────────────────────────────────────────────
# Get these from: https://app.shiprocket.in → Settings → API
SHIPROCKET_EMAIL=your-shiprocket-email
SHIPROCKET_PASSWORD=your-shiprocket-password

# ── Resend (Transactional Email) ──────────────────────────────────────────────
# Get this from: https://resend.com → API Keys
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=orders@rareease.com                    # Must be a verified sender

# ── Admin Authentication ──────────────────────────────────────────────────────
ADMIN_SECRET=your-strong-admin-secret-min-32-chars       # Used to sign admin JWT tokens

# ── Rate Limiting (Upstash Redis) — Optional but strongly recommended in prod ─
# Get these from: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Sentry Error Monitoring — Optional ───────────────────────────────────────
# Get these from: https://sentry.io → Project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token                 # For source map uploads
NEXT_PUBLIC_APP_ENV=production                           # production | staging | development
